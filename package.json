{
  "name": "react-klinecharts",
  "version": "0.1.0",
  "description": "A flexible React wrapper for KlineCharts with hooks, declarative sub-components, and full TypeScript support",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "klinecharts": "^10.0.0-beta1"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "keywords": [
    "react",
    "klinecharts",
    "chart",
    "candlestick",
    "trading",
    "financial",
    "k-line",
    "technical-analysis",
    "indicators",
    "overlays"
  ],
  "author": "NemeZZiZZ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NemeZZiZZ/react-klinecharts.git"
  },
  "homepage": "https://github.com/NemeZZiZZ/react-klinecharts#readme",
  "bugs": {
    "url": "https://github.com/NemeZZiZZ/react-klinecharts/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}